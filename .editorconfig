root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.ps1]
indent_size = 4

[*.psm1]
indent_size = 4

[*.psd1]
indent_size = 4

[*.cmd]
indent_size = 4

[*.json]
indent_size = 2

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

[justfile]
indent_size = 4

[*.md]
indent_size = 2
trim_trailing_whitespace = false
